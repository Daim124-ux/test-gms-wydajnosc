       Out += ns * curAmp;\n        sum += curAmp;\n        curFreq *= Lacunarity;\n        curAmp *= Gain;\n    }\n    if (bool(Normalize))\n        Out /= sum / Amplitude;\n    \n    #if __VERSION__ == 100\n    #undef Octaves\n    #endif\n}\n","globalVariables":[],"initializers":[["void node_osl_noise_init_0(vec3 P, out vec3 UVW) {\n    UVW = vec3(oslTransform(OSL_OBJECT, P));\n}\n",["P"]],null,null,null,null,null,null,null,null,null,null,null],"inputTypes":["vec3","float","int","int","float","float","int","float","float","int","float","float"],"inputs":[[0,0,0],1.0,"OSL_UPERLIN",4,2.0,0.5,1,0.5,0.800000011920929,1,1.0,0.0],"is_active_output":false,"name":"Map #4","outputTypes":["float"],"outputs":[0],"shaderName":"node_osl_noise","type":"OSL_NODE"},{"fragCode":"void node_osl_uvwtransform(vec3 Input, float Scale, vec3 Tiling, vec3 Offset, int Wrap, int RealWorld, float RealWidth, float RealHeight, float Rotate, vec3 RotCenter, vec3 RotAxis, out vec3 UVW) {\n    vec3 worldScale = vec3(1.0);\n    if (bool(RealWorld))\n        worldScale = vec3(RealWidth, RealHeight, 1.0);\n    UVW = oslRotate(Input - Offset, radians(Rotate), RotCenter, RotCenter + RotAxis) * Tiling / worldScale / vec3(Scale);\n    if (bool(Wrap))\n        UVW -= floor(UVW);\n}\n","globalVariables":[],"initializers":[["void node_osl_uvwtransform_init_0(float u, float v, out vec3 Input) {\n    Input = vec3(u, v, 0);\n}\n",["u","v"]],null,null,null,null,null,null,null,null,null,null],"inputTypes":["vec3","float","vec3","vec3","int","int","float","float","float","vec3","vec3"],"inputs":[[0,0,0],1.0,[1.0,100.0,100.0],[0.0,0.0,0.0],0,0,20.0,20.0,0.0,[0.5,0.5,0.0],[0.0,0.0,1.0]],"is_active_output":false,"name":"Map #5","outputTypes":["vec3"],"outputs":[[0,0,0]],"shaderName":"node_osl_uvwtransform","type":"OSL_NODE"},{"inputs":[],"name":"Material #50_Transparency","outputs":[0.0],"type":"VALUE_MX"}]},"profile":"max"}},"name":"Material #50"},{"doubleSided":false,"emissiveFactor":[0.0,0.0,0.0],"name":"Materia